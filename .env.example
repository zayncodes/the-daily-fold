# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys. In CI, set these as GitHub Secrets.

# News source — get a free key at https://newsdata.io
NEWSDATA_API_KEY=

# AI rewrite — get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: model + effort for the daily rewrite (defaults shown)
# EDITION_MODEL=claude-opus-4-8     # or claude-haiku-4-5 (cheapest), claude-sonnet-4-6
# EDITION_EFFORT=medium             # low | medium | high
